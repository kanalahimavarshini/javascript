function longestConsecutive(nums) {
    const set = new Set(nums);

    let longest = 0;

    for (const num of set) {
        if (!set.has(num - 1)) {
            let current = num;
            let streak = 1;

            while (
                set.has(current + 1)
            ) {
                current++;
                streak++;
            }

            longest =
                Math.max(
                    longest,
                    streak
                );
        }
    }

    return longest;
}
function happyNumber(n) {
    const seen = new Set();

    while (
        n !== 1 &&
        !seen.has(n)
    ) {
        seen.add(n);

        n = String(n)
            .split("")
            .reduce(
                (sum, digit) =>
                    sum +
                    digit * digit,
                0
            );
    }

    return n === 1;
}
