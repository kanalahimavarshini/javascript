function rangeUpdate(n, updates) {
    let diff = Array(n).fill(0);

    for (const [l, r, val] of updates) {
        diff[l] += val;

        if (r + 1 < n)
            diff[r + 1] -= val;
    }

    for (let i = 1; i < n; i++) {
        diff[i] += diff[i - 1];
    }

    return diff;
}
function withTimeout(promise, ms) {
