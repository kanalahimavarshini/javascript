function cloneGraph(node) {
    const map = new Map();

    function dfs(curr) {
        if (!curr) return null;

        if (map.has(curr)) {
            return map.get(curr);
        }

        const copy = {
            val: curr.val,
            neighbors: []
        };

        map.set(curr, copy);

        for (const next of curr.neighbors) {
            copy.neighbors.push(dfs(next));
        }

        return copy;
    }

    return dfs(node);
}
function floodFill(image, sr, sc, color) {
    const original = image[sr][sc];

    if (original === color) return image;

    function dfs(r, c) {
        if (
            r < 0 || c < 0 ||
            r >= image.length ||
            c >= image[0].length ||
            image[r][c] !== original
        ) {
            return;
        }

        image[r][c] = color;

        dfs(r + 1, c);
        dfs(r - 1, c);
        dfs(r, c + 1);
        dfs(r, c - 1);
    }

    dfs(sr, sc);

    return image;
}
function exist(board, word) {
