    for (let i = 0; i < words.length - 1; i++) {
        const a = words[i];
        const b = words[i + 1];

        for (let j = 0; j < Math.min(a.length, b.length); j++) {
            if (a[j] !== b[j]) {
                graph[a[j]].add(b[j]);
                break;
            }
        }
    }

    return graph;
}
function characterReplacement(s, k) {
    const count = {};
    let left = 0;
    let maxFreq = 0;
    let answer = 0;

    for (let right = 0; right < s.length; right++) {
        count[s[right]] =
            (count[s[right]] || 0) + 1;

        maxFreq = Math.max(maxFreq, count[s[right]]);

        while (
            right - left + 1 - maxFreq > k
        ) {
            count[s[left]]--;
            left++;
        }

        answer = Math.max(
            answer,
            right - left + 1
        );
    }

    return answer;
}
