    let cols = matrix[0].length;

    let left = 0;
    let right = rows * cols - 1;

    while (left <= right) {
        const mid = Math.floor((left + right) / 2);

        const value =
            matrix[Math.floor(mid / cols)][mid % cols];

        if (value === target) {
