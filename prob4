function slidingWindowMin(nums, k) {
    const deque = [];
    const result = [];

    for (let i = 0; i < nums.length; i++) {

        while (
            deque.length &&
            deque[0] <= i - k
        ) {
            deque.shift();
        }

        while (
            deque.length &&
            nums[deque.at(-1)] >= nums[i]
        ) {
            deque.pop();
        }

        deque.push(i);

        if (i >= k - 1) {
            result.push(nums[deque[0]]);
        }
    }

    return result;
}
function topKFrequent(nums, k) {
    const freq = {};

    for (const num of nums) {
        freq[num] = (freq[num] || 0) + 1;
    }

    return Object.entries(freq)
        .sort((a, b) => b[1] - a[1])
        .slice(0, k)
        .map(x => Number(x[0]));
}

