function nextGreaterElement(nums) {
    const result = Array(nums.length).fill(-1);
    const stack = [];

    for (let i = 0; i < nums.length; i++) {
        while (
            stack.length &&
            nums[i] > nums[stack.at(-1)]
        ) {
            const idx = stack.pop();
            result[idx] = nums[i];
        }

        stack.push(i);
    }

    return result;
}

