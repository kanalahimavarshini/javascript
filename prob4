function promiseAny(promises) {
    return new Promise((resolve, reject) => {
        let errors = [];
        let pending = promises.length;

        promises.forEach((promise, index) => {
            Promise.resolve(promise)
                .then(resolve)
                .catch(error => {
                    errors[index] = error;
                    pending--;

                    if (pending === 0) {
                        reject(new AggregateError(errors));
                    }
                });
        });
    });
}