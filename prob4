);
function shuntingYard(tokens) {
    let output = [];
    let operators = [];

    const precedence = {
        "+": 1,
        "-": 1,
        "*": 2,
        "/": 2
    };

    for (const token of tokens) {
        if (!isNaN(token)) {
            output.push(token);
        } else {
            while (
                operators.length &&
                precedence[operators.at(-1)] >= precedence[token]
            ) {
                output.push(
                    operators.pop()
                );
            }

            operators.push(token);
        }
    }

    return output.concat(
        operators.reverse()
    );
}
