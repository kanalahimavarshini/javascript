class MinStack {
    constructor() {
        this.stack = [];
        this.minStack = [];
    }

    push(val) {
        this.stack.push(val);

        if (
            !this.minStack.length ||
            val <= this.getMin()
        ) {
            this.minStack.push(val);
        }
    }

    pop() {
        if (
            this.stack.pop() ===
            this.getMin()
        ) {
            this.minStack.pop();
        }
    }

    getMin() {
        return this.minStack.at(-1);
    }
}
class CircularQueue {
    constructor(k) {
        this.queue = Array(k);
        this.front = 0;
        this.rear = 0;
        this.size = 0;
    }

    enqueue(val) {
        if (this.size === this.queue.length)
            return false;

        this.queue[this.rear] = val;
        this.rear =
            (this.rear + 1) %
            this.queue.length;

        this.size++;

        return true;
    }

    dequeue() {
        if (this.size === 0)
            return false;

        this.front =
            (this.front + 1) %
            this.queue.length;

        this.size--;

        return true;
    }
}
class RWLock {
    constructor() {
        this.readers = 0;
        this.writer = false;
    }

    acquireRead() {
        if (!this.writer)
            this.readers++;
    }

    releaseRead() {
        this.readers--;
    }

    acquireWrite() {
        if (
            this.readers === 0 &&
            !this.writer
        ) {
            this.writer = true;
        }
    }

    releaseWrite() {
        this.writer = false;
    }
}
const factorial = (() => {
    const memo = {};

    return function f(n) {
        if (n <= 1)
            return 1;

        if (memo[n])
            return memo[n];

        return memo[n] =
            n * f(n - 1);
    };
})();

