function infixToPostfix(expr) {
    let stack = [];
    let output = "";

    const precedence = {
        "+": 1,
        "-": 1,
        "*": 2,
        "/": 2
    };

    for (const ch of expr) {
        if (/\d/.test(ch)) {
            output += ch;
        } else {
            while (
                stack.length &&
                precedence[stack.at(-1)] >= precedence[ch]
            ) {
                output += stack.pop();
            }

            stack.push(ch);
        }
    }

    while (stack.length)
        output += stack.pop();

    return output;
}

