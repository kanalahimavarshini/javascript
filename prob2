    maxSlidingWindow([1,3,-1,-3,5,3,6,7], 3)
);
function longestCommonPrefix(strs) {
    if (!strs.length) return "";

    let prefix = strs[0];

    for (let i = 1; i < strs.length; i++) {
        while (
            strs[i].indexOf(prefix) !== 0
        ) {
            prefix = prefix.slice(0, -1);
        }
    }

    return prefix;
}

