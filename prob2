function rateLimiter(fn, limit) {
    let lastCall = 0;

    return function (...args) {
        const now = Date.now();

        if (now - lastCall >= limit) {
            lastCall = now;
            fn.apply(this, args);
        }
    };
}

const log = rateLimiter(
    () => console.log("Executed"),
    1000
);

log();
class TrieNode {
    constructor() {
        this.children = {};
        this.isEnd = false;
    }
}

class Trie {
    constructor() {
        this.root = new TrieNode();
    }

    insert(word) {
        let node = this.root;

        for (const ch of word) {
            if (!node.children[ch]) {
                node.children[ch] = new TrieNode();
            }
            node = node.children[ch];
        }

        node.isEnd = true;
    }

    startsWith(prefix) {
        let node = this.root;

        for (const ch of prefix) {
            if (!node.children[ch]) return false;
            node = node.children[ch];
        }

        return true;
    }
}
class PriorityQueue {
    constructor() {
        this.heap = [];
    }

    enqueue(val) {
        this.heap.push(val);
        this.heap.sort((a, b) => a - b);
    }

    dequeue() {
        return this.heap.shift();
    }

    peek() {
        return this.heap[0];
    }
}

