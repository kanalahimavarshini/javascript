);
function isValid(s) {
    const stack = [];
    const map = {
        ')': '(',
        '}': '{',
        ']': '['
    };

    for (const ch of s) {
        if (ch in map) {
            if (stack.pop() !== map[ch])
                return false;
        } else {
            stack.push(ch);
        }
    }

    return stack.length === 0;
}

