class TrieNode {
    constructor() {
        this.children = {};
        this.end = false;
    }
}

class Trie {
    constructor() {
        this.root = new TrieNode();
    }

    insert(word) {
        let node = this.root;

        for (let char of word) {
            if (!node.children[char])
                node.children[char] = new TrieNode();

            node = node.children[char];
        }

        node.end = true;
    }

    search(word) {
        let node = this.root;

        for (let char of word) {
            if (!node.children[char])
                return false;

            node = node.children[char];
        }

        return node.end;
    }
}

