class Middleware {
    constructor() {
        this.middlewares = [];
    }

    use(fn) {
        this.middlewares.push(fn);
    }

    execute(context) {
        let index = 0;

        const next = () => {
            if (index < this.middlewares.length) {
                this.middlewares[index++](
                    context,
                    next
                );
            }
        };

        next();
    }
}

