function kruskal(edges, n) {
    const parent = Array.from(
        { length: n },
        (_, i) => i
    );

    function find(x) {
        return parent[x] === x
            ? x
            : parent[x] = find(parent[x]);
    }

    edges.sort((a, b) => a[2] - b[2]);

    let cost = 0;

    for (const [u, v, w] of edges) {
        const pu = find(u);
        const pv = find(v);

        if (pu !== pv) {
            parent[pu] = pv;
            cost += w;
        }
    }

    return cost;
}
function prim(graph) {
    const visited = new Set();
    const pq = [[0, 0]];
    let cost = 0;

    while (pq.length) {
        pq.sort((a, b) => a[0] - b[0]);

        const [weight, node] = pq.shift();

        if (visited.has(node))
            continue;

        visited.add(node);
        cost += weight;

        for (const [next, w] of graph[node]) {
            if (!visited.has(next)) {
                pq.push([w, next]);
            }
        }
    }

    return cost;
}
class LRUCache {
    constructor(capacity) {
        this.capacity = capacity;
        this.map = new Map();
    }

    get(key) {
        if (!this.map.has(key))
            return -1;

        const val = this.map.get(key);

        this.map.delete(key);
        this.map.set(key, val);

        return val;
    }

    put(key, value) {
        if (this.map.has(key))
            this.map.delete(key);

        this.map.set(key, value);

        if (this.map.size > this.capacity) {
            this.map.delete(
                this.map.keys().next().value
            );
        }
    }
}
